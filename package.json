{
    "name": "topo",
    "version": "1.0.0",
    "description": "网络拓扑绘制软件",
    "main": "./main.js",
    "scripts": {
        "dev": "powershell -Command \"$env:ELECTRON_RUN_AS_NODE=''; $env:ATOM_SHELL_INTERNAL_RUN_AS_NODE=''; npx electron-vite dev\"",
        "dev:renderer": "npx vite --config src/renderer/vite.config.ts",
        "build": "powershell -Command \"$env:ELECTRON_RUN_AS_NODE=''; $env:ATOM_SHELL_INTERNAL_RUN_AS_NODE=''; npx electron-vite build\"",
        "start": "powershell -Command \"$env:ELECTRON_RUN_AS_NODE=''; $env:ATOM_SHELL_INTERNAL_RUN_AS_NODE=''; .\\node_modules\\electron\\dist\\electron.exe .\"",
        "pack": "npm run build && npx electron-builder --win portable",
        "dist": "npm run build && npx electron-builder --win",
        "postinstall": "electron-builder install-app-deps"
    },
    "author": "",
    "license": "MIT",
    "build": {
        "appId": "com.topo.network",
        "productName": "Topo",
        "directories": {
            "output": "dist"
        },
        "files": [
            "out/**/*",
            "main.js",
            "package.json"
        ],
        "win": {
            "target": [
                "nsis",
                "portable"
            ],
            "icon": "resources/icon.ico"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "language": "2052"
        },
        "asarUnpack": [
            "node_modules/better-sqlite3/**"
        ]
    },
    "dependencies": {
        "@xyflow/react": "^12.11.1",
        "better-sqlite3": "^12.11.1",
        "gif.js": "^0.2.0",
        "html-to-image": "^1.11.13",
        "jspdf": "^4.2.1",
        "react": "^18.3.1",
        "react-dom": "^18.3.1"
    },
    "devDependencies": {
        "@electron/rebuild": "^4.0.1",
        "@types/better-sqlite3": "^7.6.13",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^4.7.0",
        "autoprefixer": "^10.5.2",
        "electron": "^31.7.7",
        "electron-builder": "^26.15.3",
        "electron-vite": "^2.3.0",
        "postcss": "^8.5.15",
        "tailwindcss": "^3.4.19",
        "typescript": "^5.9.3",
        "vite": "^5.4.21"
    }
}
